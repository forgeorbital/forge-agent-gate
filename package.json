{
  "name": "forge-agent-gate",
  "version": "0.1.6",
  "description": "Self-serve developer on-ramp to Forge Orbital: a local, deterministic mandate gate for AI agents that take consequential actions. Every allow and block is sent to Forge for a verifiable proof trail.",
  "type": "module",
  "license": "MIT",
  "author": "Forge Orbital",
  "homepage": "https://forgeorbital.com/agent-gate",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forgeorbital/forge-agent-gate.git"
  },
  "bugs": {
    "url": "https://github.com/forgeorbital/forge-agent-gate/issues"
  },
  "mcpName": "com.forgeorbital/agent-gate",
  "bin": {
    "forge-agent-gate": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "llms-install.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build:test && node --test .test-build/test/*.test.js",
    "test:watch": "npm run build:test && node --test --watch .test-build/test/*.test.js",
    "serve": "node dist/cli.js serve",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "agent-actions",
    "agent-guardrails",
    "risk-control",
    "policy-enforcement",
    "proof-trail",
    "audit-trail",
    "approvals",
    "refunds",
    "payments",
    "procurement",
    "prediction-markets",
    "kalshi",
    "trading-agent",
    "guardrails",
    "forge"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "typescript": "5.9.3"
  }
}
