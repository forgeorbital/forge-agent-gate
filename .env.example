# ---------------------------------------------------------------------------
# Forge Agent Gate - example environment
# Copy to .env and fill in. NEVER commit the real .env.
# Venue private keys stay LOCAL. They are never sent to Forge and never logged.
# ---------------------------------------------------------------------------

# --- Forge accountability layer (proof-trail layer) -------------------------
# API key for the Forge decision API. Forge keys start with fi_.
FORGE_API_KEY=
# Or use a bearer JWT instead of an API key (leave blank if using FORGE_API_KEY):
# FORGE_BEARER_TOKEN=
FORGE_API_BASE_URL=https://forgeorbital.com
# required  = fail-closed: if Forge cannot write the proof trail, the order is BLOCKED.
# best_effort = execute even if the Forge proof trail could not be written.
FORGE_RECORD_MODE=required

# --- Caller identity (stamped into every proof trail) ------------------------
FORGE_TENANT_ID=your-tenant-id
AGENT_GATE_AGENT_ID=trading-agent-prod-1
AGENT_GATE_AGENT_VERSION=0.1.0

# --- Local operator state ---------------------------------------------------
# Signed mandate (policy) file. Created by `forge-agent-gate init`.
AGENT_GATE_MANDATE_PATH=./mandate.json
# If this file EXISTS, every write (place_order / cancel_order) is hard-blocked.
AGENT_GATE_KILL_FILE=./.forge-agent-gate.kill

# --- Kalshi (native adapter, RSA-PSS signed) --------------------------------
# API Key ID from the Kalshi dashboard.
KALSHI_API_KEY_ID=
# Provide the RSA private key by PATH (preferred) or inline PEM. Never commit it.
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
# KALSHI_PRIVATE_KEY_PEM="<inline RSA private key PEM if you cannot use a file>"
# prod | demo
KALSHI_ENV=demo

# --- pmxt passthrough (optional, other venues) ------------------------------
# Only used if the optional `pmxtjs` dependency is installed and configured.
PMXT_API_KEY=
# PMXT_WALLET_ADDRESS=
# PMXT_PRIVATE_KEY=
